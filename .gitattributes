# Normalise les fins de ligne : LF dans le repo, natif au checkout
* text=auto

# Forcer LF pour les fichiers source
*.dart text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.swift text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.plist text eol=lf
*.xcconfig text eol=lf
*.storyboard text eol=lf
*.entitlements text eol=lf
*.h text eol=lf
*.sh text eol=lf

# Fichiers binaires — ne pas toucher
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
